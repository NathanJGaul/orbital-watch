// Check that Telemetry api is functioning (with default page length of 20)
GET {{host}}:{{port}}/api/satellites/1/telemetry

> {%
    client.test("Telemetry array length check", function () {
        client.assert(response.body.length === 20, "Expected length 20, got " + response.body.length);
    });
%}

###

// Check for latest Telemetry api function
GET {{host}}:{{port}}/api/satellites/1/telemetry/latest

> {%
    client.log("Latest telemetry latitude: " + response.body.latitudeDeg)
%}

###

// Step 1 -- Negotiate a SignalR connection and extract the connection token
// (the ?negotiateVersion=1 query param returns a separate connectionToken field)
POST {{host}}:{{port}}/hubs/telemetry/negotiate?negotiateVersion=1

> {%
    if (response.body.connectionToken) {
        client.global.set("signalr_token", response.body.connectionToken);
    } else {
        client.global.set("signalr_token", response.body.connectionId);
    }
    client.log("SignalR connection token: " + client.global.get("signalr_token"));
%}

###

// Step 2 (manual) -- Open a WebSocket with the token from step 1:
//   wscat -c "ws://{{host}}:{{port}}/hubs/telemetry?id={{signalr_token}}"
//
// Step 3 (manual) -- After wscat connects, send the SignalR handshake:
//   {"protocol":"json","version":1}
//
// Expected response (1.5 s timeout):
//   {}  (empty JSON object signals handshake accepted)
//
// Step 4 (manual) -- Subscribe to satellite 1:
//   {"type":1,"target":"SubscribeToSatellite","arguments":[1]}
//
// Within ~2 seconds you should receive:
//   {"type":1,"target":"Subscribed","arguments":[1]}
//   {"type":1,"target":"TelemetryUpdate","arguments":[{"id":...,"satelliteId":1,"latitudeDeg":23.4,...}]}
//   {"type":1,"target":"TelemetryUpdate","arguments":[{"id":...,"satelliteId":1,"latitudeDeg":23.7,...}]}
//
// The TelemetryUpdate messages arrive every ~500 ms from TelemetrySimulatorService.